{
  "name": "elysia-drizzle-mysql",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && esbuild src/server.ts --bundle --platform=node --outdir=dist --format=cjs",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate:mysql",
    "db:migrate": "drizzle-kit migrate:mysql",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push:mysql",
    "db:drop": "drizzle-kit drop",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "mysql2": "^3.22.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.7.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "module": "src/server.ts",
  "type": "module",
  "private": true
}
